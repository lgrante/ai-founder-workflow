<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>$title$ — Architecture</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0d1117;
      --surface: #161b22;
      --surface-2: #1c2128;
      --border: #30363d;
      --text: #e6edf3;
      --muted: #8b949e;
      --accent: #3fb950;
      --blue: #58a6ff;
      --purple: #bc8cff;
      --pink: #f778ba;
      --yellow: #d29922;
      --red: #f85149;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      font-size: 16px;
      padding: 32px 20px 64px;
      max-width: 920px;
      margin: 0 auto;
      -webkit-font-smoothing: antialiased;
    }

    header.doc-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      padding-bottom: 24px;
      margin-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    header.doc-meta .tag {
      background: var(--surface);
      color: var(--accent);
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 0.75em;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border: 1px solid var(--border);
    }
    header.doc-meta .feature {
      font-family: 'JetBrains Mono', monospace;
      color: var(--muted);
      font-size: 0.95em;
    }

    h1, h2, h3, h4 {
      font-weight: 600;
      line-height: 1.3;
      margin: 1.8em 0 0.6em;
    }
    h1 {
      font-size: 2em;
      color: var(--accent);
      border-bottom: 2px solid var(--border);
      padding-bottom: 0.3em;
      margin-top: 0;
    }
    h2 {
      font-size: 1.5em;
      color: var(--blue);
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.25em;
    }
    h3 {
      font-size: 1.2em;
      color: var(--purple);
    }
    h4 {
      font-size: 1.05em;
      color: var(--muted);
    }

    p, ul, ol, blockquote { margin: 1em 0; }
    ul, ol { padding-left: 1.6em; }
    li { margin: 0.25em 0; }

    strong { color: var(--text); font-weight: 600; }
    em { color: var(--yellow); }

    code {
      font-family: 'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace;
      background: var(--surface-2);
      padding: 0.15em 0.45em;
      border-radius: 4px;
      font-size: 0.9em;
      border: 1px solid var(--border);
    }
    pre {
      background: var(--surface-2);
      padding: 1em 1.2em;
      border-radius: 8px;
      overflow-x: auto;
      border: 1px solid var(--border);
      font-size: 0.9em;
    }
    pre code {
      background: transparent;
      border: 0;
      padding: 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.2em 0;
      font-size: 0.95em;
    }
    th, td {
      padding: 0.65em 0.85em;
      text-align: left;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    th {
      background: var(--surface);
      color: var(--blue);
      font-weight: 600;
      border-bottom: 2px solid var(--border);
    }
    tr:hover td { background: var(--surface); }

    blockquote {
      border-left: 3px solid var(--accent);
      background: var(--surface);
      padding: 0.6em 1em;
      color: var(--muted);
      border-radius: 0 6px 6px 0;
    }
    blockquote p:first-child { margin-top: 0; }
    blockquote p:last-child { margin-bottom: 0; }

    a {
      color: var(--blue);
      text-decoration: none;
      border-bottom: 1px dotted var(--blue);
    }
    a:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    hr {
      border: 0;
      border-top: 1px solid var(--border);
      margin: 2em 0;
    }

    /* Mermaid containers */
    .mermaid {
      background: var(--surface);
      padding: 1.5em 1em;
      border-radius: 8px;
      margin: 1.2em 0;
      border: 1px solid var(--border);
      text-align: center;
      overflow-x: auto;
    }
    .mermaid svg { max-width: 100%; height: auto; }

    footer.doc-meta {
      margin-top: 3em;
      padding-top: 1.2em;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.85em;
      text-align: center;
    }
    footer.doc-meta a { color: var(--muted); border-bottom-color: var(--border); }

    /* Responsive */
    @media (max-width: 720px) {
      body { padding: 24px 14px 48px; font-size: 15px; }
      h1 { font-size: 1.6em; }
      h2 { font-size: 1.3em; }
      h3 { font-size: 1.1em; }
      table { font-size: 0.88em; display: block; overflow-x: auto; }
      pre { font-size: 0.82em; padding: 0.8em; }
      header.doc-meta { gap: 8px; }
    }
    @media (max-width: 480px) {
      body { padding: 20px 12px 40px; }
      h1 { font-size: 1.45em; }
      .mermaid { padding: 1em 0.5em; font-size: 0.85em; }
    }
  </style>
</head>
<body>
  <header class="doc-meta">
    <span class="tag">Architecture</span>
    <span class="feature">$title$</span>
  </header>

  <main>
$body$
  </main>

  <footer class="doc-meta">
    <p><code>ARCHITECTURE.md</code> · ai-founder-workflow · diagrammes Mermaid rendus côté client</p>
  </footer>

  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';

    // Pandoc rend ```mermaid``` en <pre><code class="mermaid">…</code></pre> ; on convertit en <div class="mermaid">…</div> pour mermaid.run.
    document.querySelectorAll('pre code.language-mermaid, pre code.mermaid, code.language-mermaid').forEach(el => {
      const parent = el.closest('pre') || el.parentElement;
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = el.textContent;
      parent.replaceWith(div);
    });

    mermaid.initialize({
      startOnLoad: true,
      theme: 'dark',
      themeVariables: {
        background: '#0d1117',
        primaryColor: '#161b22',
        primaryTextColor: '#e6edf3',
        primaryBorderColor: '#30363d',
        lineColor: '#58a6ff',
        secondaryColor: '#1c2128',
        tertiaryColor: '#161b22',
        fontFamily: 'Inter, sans-serif',
        fontSize: '14px'
      },
      flowchart: { curve: 'basis', padding: 16, useMaxWidth: true },
      sequence: { actorMargin: 50, useMaxWidth: true },
      er: { useMaxWidth: true }
    });
  </script>
</body>
</html>
